#!/usr/bin/env bash
# Launcher for the simple streaming tester (chat.py) so you can run `nimchat "..."`
# from anywhere. Resolves symlinks; uses the project venv.
set -euo pipefail
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
DIR="$(cd "$(dirname "$SELF")/.." && pwd)"   # project root (parent of bin/)
exec "$DIR/.venv/bin/python" "$DIR/chat.py" "$@"
